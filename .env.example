# Copy this file to ".env" and fill in your own values.

# MongoDB connection string (MongoDB Atlas for production, or local for dev).
# If omitted, the app falls back to mongodb://127.0.0.1:27017/wanderlust
ATLASDB_URL=

# Secret used to sign sessions and encrypt the session store.
SECRET=replace_with_a_long_random_string

# Cloudinary (image uploads)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Gmail SMTP for email OTP verification.
# Leave SMTP_EMAIL / SMTP_APP_PASSWORD blank to use the dev fallback
# (the OTP is printed to the server console instead of being emailed).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=
SMTP_APP_PASSWORD=
SMTP_FROM_EMAIL=

# Set to "production" on your host (Render, etc.)
NODE_ENV=

# Set to "true" to show the OTP on-screen (demo convenience when email is slow)
DEMO_SHOW_OTP=false
