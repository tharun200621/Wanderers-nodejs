<% layout("/layouts/boilerplate")%>

<div class="row mt-5 mb-5">
  <div class="col-md-5 offset-md-3">
    <div class="panel">
      <h2 class="mb-1">Welcome back</h2>
      <p class="text-muted mb-4">Log in to continue your journey.</p>
      <form action="/login" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input name="username" id="username" type="text" class="form-control" required />
        </div>
        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input name="password" id="password" type="password" class="form-control" required />
        </div>
        <div class="mb-4 form-check">
          <input type="checkbox" class="form-check-input" name="remember" id="remember" value="true" />
          <label class="form-check-label" for="remember">Remember me on this device</label>
        </div>
        <button class="btn btn-success">Log In</button>
      </form>
      <p class="text-muted mt-3 mb-0">New here? <a href="/signup">Create an account</a></p>
    </div>
  </div>
</div>
