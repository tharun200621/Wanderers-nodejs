<% layout("/layouts/boilerplate")%>

<div class="row mt-5 mb-5">
  <div class="col-md-5 offset-md-3">
    <div class="panel">
      <h2 class="mb-1">Verify your email</h2>
      <p class="text-muted mb-4">Enter the 6-digit code we emailed you. It expires in 10 minutes.</p>
      <% if (typeof demoOtp !== "undefined" && demoOtp) { %>
        <div class="alert alert-success" role="alert">
          <strong>Demo mode:</strong> your code is <strong style="letter-spacing:3px;"><%= demoOtp %></strong>
          <div style="font-size:0.8rem;">(Email delivery can be slow on free hosting — shown here for convenience.)</div>
        </div>
      <% } %>
      <form action="/verify-otp" method="POST">
        <div class="mb-4">
          <label for="otp" class="form-label">Verification code</label>
          <input name="otp" id="otp" type="text" inputmode="numeric" autocomplete="one-time-code" maxlength="6"
                 class="form-control" style="letter-spacing:6px; font-size:1.3rem; text-align:center;" required />
        </div>
        <button class="btn btn-success">Verify</button>
      </form>
      <form action="/resend-otp" method="POST" class="mt-3">
        <button class="btn btn-outline-dark">Resend code</button>
      </form>
      <script>
        const otpInput = document.getElementById("otp");
        otpInput.addEventListener("input", () => {
          otpInput.value = otpInput.value.replace(/\D/g, "").slice(0, 6);
        });
      </script>
    </div>
  </div>
</div>
